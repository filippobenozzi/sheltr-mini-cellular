{
  "name": "sheltr-cloud-frontend",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "ui:add": "bun ./node_modules/shadcn/dist/index.js add",
    "ui:info": "bun ./node_modules/shadcn/dist/index.js info"
  },
  "dependencies": {
    "@fontsource-variable/inter": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "shadcn": "latest",
    "sonner": "^2.0.7",
    "tailwind-merge": "latest",
    "tw-animate-css": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
